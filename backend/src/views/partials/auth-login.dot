<form class="login-form" id="login-form" novalidate>
  <p class="form-message" id="form-message" aria-live="polite"></p>

  <div class="form-group">
    <label for="email" data-i18n="login.email">Email</label>
    <input id="email" name="email" type="email" autocomplete="email" placeholder="student@example.com" data-i18n-placeholder="login.emailPlaceholder">
    <small class="field-error" data-error-for="email"></small>
  </div>

  <div class="form-group">
    <label for="password" data-i18n="login.password">Password</label>
    <input id="password" name="password" type="password" autocomplete="current-password" placeholder="Enter your password" data-i18n-placeholder="login.passwordPlaceholder">
    <small class="field-error" data-error-for="password"></small>
  </div>

  <button type="submit" class="submit-button" data-i18n="login.submit">Log In</button>
</form>
