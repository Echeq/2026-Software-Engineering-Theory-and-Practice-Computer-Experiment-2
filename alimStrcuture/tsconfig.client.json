{
  "compilerOptions": {
    "target": "ES2020",
    "module": "none",
    "lib": ["DOM", "ES2020"],
    "outDir": "./public/js",
    "rootDir": "./public/ts",
    "strict": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "removeComments": false
  },
  "include": ["public/ts/**/*.ts"],
  "exclude": ["node_modules", "public/js"]
}
