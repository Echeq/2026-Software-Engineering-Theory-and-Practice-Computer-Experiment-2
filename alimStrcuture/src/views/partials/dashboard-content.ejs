<section id="dashboard-content" class="dashboard-grid">
  <%- include("flash", { flash }) %>

  <div class="stats">
    <article class="stat-card">
      <span class="muted tiny">Projects</span>
      <strong><%= projects.length %></strong>
    </article>
    <article class="stat-card">
      <span class="muted tiny">Visible tasks</span>
      <strong><%= totalTasks %></strong>
    </article>
    <article class="stat-card">
      <span class="muted tiny">Completed</span>
      <strong><%= completedTasks %></strong>
    </article>
  </div>

  <div class="content-grid">
    <aside class="panel stack-gap">
      <div>
        <h2>Create project</h2>
        <p class="muted">Keep everything in one local Express app. HTMX swaps only this dashboard section.</p>
      </div>

      <form
        class="project-form"
        hx-post="/projects"
        hx-target="#dashboard-content"
        hx-swap="outerHTML"
      >
        <div class="field">
          <label for="project-name">Project name</label>
          <input id="project-name" name="name" value="<%= projectValues.name %>" required>
        </div>
        <div class="field">
          <label for="project-description">Description</label>
          <textarea id="project-description" name="description"><%= projectValues.description %></textarea>
        </div>
        <button class="button button-primary" type="submit">Create project</button>
      </form>
    </aside>

    <section class="stack-gap">
      <% if (projects.length === 0) { %>
        <div class="empty-state">
          No projects yet. Create the first project and tasks will stay inside this single local deployment flow.
        </div>
      <% } %>

      <div class="project-list">
        <% projects.forEach((project) => { %>
          <article class="project-card">
            <div class="project-head">
              <div>
                <h3><%= project.name %></h3>
                <% if (project.description) { %>
                  <p class="muted"><%= project.description %></p>
                <% } %>
              </div>
              <form
                hx-post="/projects/<%= project.id %>/delete"
                hx-target="#dashboard-content"
                hx-swap="outerHTML"
                data-confirm="Delete this project and all its tasks?"
              >
                <button class="button button-danger" type="submit">Delete</button>
              </form>
            </div>

            <div class="subtle-divider"></div>

            <form
              class="task-form"
              hx-post="/tasks"
              hx-target="#dashboard-content"
              hx-swap="outerHTML"
            >
              <input type="hidden" name="project_id" value="<%= project.id %>">
              <div class="field-inline">
                <div class="field">
                  <label for="task-title-<%= project.id %>">New task</label>
                  <input
                    id="task-title-<%= project.id %>"
                    name="title"
                    value="<%= taskValues.project_id === project.id ? taskValues.title : '' %>"
                    required
                  >
                </div>
                <div class="field">
                  <label for="task-priority-<%= project.id %>">Priority</label>
                  <select id="task-priority-<%= project.id %>" name="priority">
                    <option value="low" <%= (taskValues.project_id === project.id ? taskValues.priority : 'medium') === 'low' ? 'selected' : '' %>>Low</option>
                    <option value="medium" <%= (taskValues.project_id === project.id ? taskValues.priority : 'medium') === 'medium' ? 'selected' : '' %>>Medium</option>
                    <option value="high" <%= (taskValues.project_id === project.id ? taskValues.priority : 'medium') === 'high' ? 'selected' : '' %>>High</option>
                  </select>
                </div>
              </div>
              <div class="field-inline">
                <div class="field">
                  <label for="task-due-date-<%= project.id %>">Due date</label>
                  <input
                    id="task-due-date-<%= project.id %>"
                    type="date"
                    name="due_date"
                    value="<%= taskValues.project_id === project.id ? taskValues.due_date : '' %>"
                  >
                </div>
                <div class="field">
                  <label for="task-description-<%= project.id %>">Description</label>
                  <input
                    id="task-description-<%= project.id %>"
                    name="description"
                    value="<%= taskValues.project_id === project.id ? taskValues.description : '' %>"
                  >
                </div>
              </div>
              <button class="button button-secondary" type="submit">Add task</button>
            </form>

            <div class="task-list">
              <% const projectTasks = tasksByProject[project.id] || []; %>
              <% if (projectTasks.length === 0) { %>
                <div class="empty-state">No tasks in this project yet.</div>
              <% } %>

              <% projectTasks.forEach((task) => { %>
                <article class="task-card">
                  <div class="task-head">
                    <div>
                      <h4><%= task.title %></h4>
                      <% if (task.description) { %>
                        <p class="muted tiny"><%= task.description %></p>
                      <% } %>
                    </div>
                    <form
                      hx-post="/tasks/<%= task.id %>/delete"
                      hx-target="#dashboard-content"
                      hx-swap="outerHTML"
                      data-confirm="Delete this task?"
                    >
                      <button class="button button-danger" type="submit">Delete</button>
                    </form>
                  </div>

                  <div class="chip-row">
                    <span class="chip chip-neutral"><%= task.status %></span>
                    <span class="chip <%= task.priority === 'high' ? 'chip-danger' : task.priority === 'low' ? 'chip-success' : 'chip-warning' %>">
                      <%= task.priority %> priority
                    </span>
                    <% if (task.due_date) { %>
                      <span class="chip chip-neutral">Due <%= new Date(task.due_date).toLocaleDateString() %></span>
                    <% } %>
                  </div>

                  <form
                    class="status-form"
                    hx-post="/tasks/<%= task.id %>/status"
                    hx-target="#dashboard-content"
                    hx-swap="outerHTML"
                  >
                    <input type="hidden" name="status" value="">
                    <div class="button-row">
                      <button class="button button-secondary" type="submit" onclick="this.form.status.value='pending'">Pending</button>
                      <button class="button button-secondary" type="submit" onclick="this.form.status.value='in-progress'">In progress</button>
                      <button class="button button-primary" type="submit" onclick="this.form.status.value='completed'">Complete</button>
                    </div>
                  </form>
                </article>
              <% }) %>
            </div>
          </article>
        <% }) %>
      </div>
    </section>
  </div>
</section>
