<!DOCTYPE html>
<html lang="en">
  <%- include("../partials/head", { pageTitle }) %>
  <body>
    <main class="auth-shell">
      <section class="auth-card">
        <span class="eyebrow">500</span>
        <h1>Server error</h1>
        <p><%= errorMessage %></p>
        <div class="button-row">
          <a class="button-link button-primary" href="<%= currentUser ? '/dashboard' : '/login' %>">Return</a>
        </div>
      </section>
    </main>
  </body>
</html>
