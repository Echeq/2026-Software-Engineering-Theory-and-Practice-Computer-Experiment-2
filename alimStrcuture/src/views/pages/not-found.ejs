<!DOCTYPE html>
<html lang="en">
  <%- include("../partials/head", { pageTitle }) %>
  <body>
    <main class="auth-shell">
      <section class="auth-card">
        <span class="eyebrow">404</span>
        <h1>Page not found</h1>
        <p>The route you requested does not exist in the new unified structure.</p>
        <div class="button-row">
          <a class="button-link button-primary" href="<%= currentUser ? '/dashboard' : '/login' %>">Go back</a>
        </div>
      </section>
    </main>
  </body>
</html>
