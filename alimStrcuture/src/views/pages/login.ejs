<!DOCTYPE html>
<html lang="en">
<%- include("../partials/head", { pageTitle }) %>

    <body>
        <main class="auth-shell">
            <section class="auth-card">
                <span class="eyebrow">SPMP local</span>
                <h1>Sign in</h1>
                <p>Log in to your account</p>

                <% if (error) { %>
                    <div class="flash flash-error">
                        <%= error %>
                    </div>
                    <% } %>

                        <form class="form-stack" method="post" action="/login">
                            <div class="field">
                                <label for="email">Email</label>
                                <input id="email" type="email" name="email" value="<%= values.email || '' %>" required>
                            </div>

                            <div class="field">
                                <label for="password">Password</label>
                                <input id="password" type="password" name="password" required>
                            </div>

                            <div class="button-row">
                                <button class="button button-primary" type="submit">Login</button>
                                <a class="button-link button-secondary" href="/signup">Create account</a>
                            </div>
                        </form>
            </section>
        </main>
    </body>

</html>